{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bighill.io/schemas/user-event.json",
  "title": "Bighill User Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "occurred_at",
    "source_service",
    "event_type",
    "severity",
    "resource",
    "status",
    "title",
    "message"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "source_service": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["INFO", "SUCCESS", "WARNING", "ERROR"] },
    "required_permission": { "type": "string", "minLength": 1 },
    "user_id": { "type": "string", "minLength": 1 },
    "org_id": { "type": "string", "minLength": 1 },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "href": { "type": "string" }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": { "type": "string" },
        "previous_state": { "type": "string" },
        "phase": { "type": "string" },
        "progress": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "title": { "type": "string", "minLength": 1 },
    "message": { "type": "string", "minLength": 1 },
    "action_label": { "type": "string" },
    "action_href": { "type": "string" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "technical_detail": { "type": "string" },
        "retryable": { "type": "boolean" },
        "remediation": { "type": "string" }
      }
    },
    "correlation_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "anyOf": [
    { "required": ["user_id"] },
    { "required": ["org_id"] }
  ]
}
