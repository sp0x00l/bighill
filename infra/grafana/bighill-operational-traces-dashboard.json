    {
      "datasource": {
        "type": "tempo",
        "uid": "${tempo}"
      },
      "description": "Rate of error spans that represent infrastructure or transport failures: database spans, HTTP 5xx, and gRPC Unknown/Internal/Unavailable/DeadlineExceeded.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "${tempo}"
          },
          "query": "{status=error && resource.service.name != nil && (span.db.name != nil || span.db.system != nil || span.http.status_code >= 500 || span.http.response.status_code >= 500 || span.rpc.grpc.status_code = 2 || span.rpc.grpc.status_code = 4 || span.rpc.grpc.status_code = 13 || span.rpc.grpc.status_code = 14)} | rate() by(resource.service.name)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Operational Error Rate by Service",
      "type": "timeseries"
    },
